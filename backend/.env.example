# --- Supabase ---
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://roqqvtppyuahlexebnsg.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Supabase Dashboard → Settings → Database
# 1) Direct connection (현재 설정). 간단하지만 IPv6 만 지원하고 풀링 없음 → 해커톤 OK.
DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.roqqvtppyuahlexebnsg.supabase.co:5432/postgres?sslmode=require
#
# 2) 권장 — Session/Transaction pooler (IPv4 지원, 다중 컨테이너에서 안정적).
#    Dashboard 의 "Connection pooling" 섹션에서 그대로 복사 → '+psycopg2' 만 끼워넣고 sslmode=require 붙이기:
# DATABASE_URL=postgresql+psycopg2://postgres.roqqvtppyuahlexebnsg:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- LLM ---
# vLLM (CBT-Copilot 등). 로컬 또는 외부 GPU 서버.
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=thillaic/CBT-Copilot

# Gemini (주간 리포트 생성). https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
