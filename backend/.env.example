# --- Supabase ---
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://roqqvtppyuahlexebnsg.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Supabase Dashboard → Settings → Database → Connection string
# Direct connection (권장 — 우리 FastAPI 컨테이너처럼 장기 실행 프로세스용).
# IPv6 만 지원하므로 Docker / 호스트가 IPv6 안 될 때만 Session pooler 로 교체.
DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.roqqvtppyuahlexebnsg.supabase.co:5432/postgres?sslmode=require
#
# Fallback — IPv4 네트워크에서 Direct 가 안 붙으면 Session pooler 사용
# (Dashboard 의 "Session pooler" 탭에서 URI 복사 → +psycopg2 끼우고 sslmode=require 추가):
# DATABASE_URL=postgresql+psycopg2://postgres.roqqvtppyuahlexebnsg:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- LLM ---
# Gemini powers chatbot, emotion classification, period reports, and
# therapist matching. https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- CORS ---
# Comma-separated origins. Use "*" for dev; production should list your
# frontend domain(s), e.g. https://app.example.com,https://www.example.com
CORS_ORIGINS=*

# --- Logging ---
# Python logging level for the app loggers (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO

# --- Spotify ---
# https://developer.spotify.com/dashboard → Create app → copy ID/secret.
# Client Credentials Flow — no user OAuth, just an app-level key pair.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
